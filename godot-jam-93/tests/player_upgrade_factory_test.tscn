script/source = "extends Node2D

func _unhandled_input(event: InputEvent) -> void:
	if event.is_action_pressed(\"ui_accept\"):
		$Player/PlayerUpgradeTreeController.add_child($UpgradeFactory.get_common())
		$Player/PlayerUpgradeTreeController.neighbor_children_if_connection()
"

